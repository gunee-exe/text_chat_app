rules_version = '2';

// Textify security rules.
// Paste this into: Firebase console -> Firestore Database -> Rules -> Publish.
//
// Model:
//   users/{uid}            profile; readable by any signed-in user (needed to
//                          render names/avatars and to look people up)
//   usernames/{username}   { uid }  uniqueness index; doc id IS the username
//   chats/{chatId}         members-only; per-user unread/muted maps
//   chats/{chatId}/messages/{id}
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isMember(chatId) {
      return isSignedIn() &&
        request.auth.uid in
          get(/databases/$(database)/documents/chats/$(chatId)).data.memberIds;
    }

    // Profiles: any signed-in user may read (search + render); only the owner
    // may write their own.
    match /users/{uid} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && request.auth.uid == uid;
    }

    // Username index. `create` only matches when the doc doesn't exist yet, so
    // it enforces uniqueness. The reservation must point at the caller. Only
    // the owner can release their name (when changing it).
    match /usernames/{username} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && request.resource.data.uid == request.auth.uid;
      allow delete: if isSignedIn()
        && resource.data.uid == request.auth.uid;
      allow update: if false;
    }

    // Chats: only members can read or update; a creator must include themselves.
    match /chats/{chatId} {
      allow read: if isSignedIn()
        && request.auth.uid in resource.data.memberIds;
      allow create: if isSignedIn()
        && request.auth.uid in request.resource.data.memberIds;
      allow update: if isSignedIn()
        && request.auth.uid in resource.data.memberIds;
      allow delete: if false;

      // Messages: members can read; a sender can only create their own message.
      // replyTo is written here at creation and can never be mutated (the only
      // permitted update is to reactions — see below).
      match /messages/{messageId} {
        allow read: if isMember(chatId);
        allow create: if isMember(chatId)
          && request.resource.data.senderId == request.auth.uid;

        // The ONLY allowed update is to the reactions map, and within it only
        // the caller's own key (their uid) — never another field, never another
        // user's reaction.
        allow update: if isMember(chatId)
          && request.resource.data.diff(resource.data)
               .affectedKeys().hasOnly(['reactions'])
          && request.resource.data.get('reactions', {})
               .diff(resource.data.get('reactions', {}))
               .affectedKeys().hasOnly([request.auth.uid]);

        allow delete: if false;
      }
    }
  }
}
